# ================= SIMBIONTE — Variables del servidor =================
# Copia este archivo como ".env" y completa solo lo que vayas a usar.
# TODO es opcional: sin .env el proyecto funciona igual (modo memoria).

# --- Supabase (persistencia del ecosistema) ---
# 1. Crea un proyecto gratis en https://supabase.com
# 2. Ve a Project Settings → API y copia estos dos valores:
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Cronista IA (opcional) ---
# Clave de la API de Anthropic para que la mitología la escriba Claude.
# Sin clave, el proyecto usa el generador local de mitos (también queda bien).
ANTHROPIC_API_KEY=

# --- Puerto del servidor ---
PORT=3000
